# ─────────────────────────────────────────────────────────────
#  ThreatX SOC — Environment Configuration
#
#  1. Copy this file:   cp .env.example .env
#  2. Fill in your keys (see README.md for where to get them)
#  3. Never commit .env — it is already in .gitignore
# ─────────────────────────────────────────────────────────────

# ── AbuseIPDB ─────────────────────────────────────────────────
# Free tier: 1,000 IP checks/day
# Get key → https://www.abuseipdb.com/account/api
ABUSEIPDB_KEY=your_abuseipdb_api_key_here

# ── VirusTotal ────────────────────────────────────────────────
# Free tier: 4 lookups/min, 500/day
# Get key → https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_KEY=your_virustotal_api_key_here

# ── Flask server ──────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ── Detection engine ──────────────────────────────────────────
# How often (seconds) to poll Sysmon for new events (default: 30)
POLL_INTERVAL=30
